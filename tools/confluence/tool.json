{
  "name": "confluence",
  "description": "Interact with Atlassian Confluence via the confluence-cli binary installed on the gateway host. Assumes the host is already authenticated. Supports reading pages, searching, listing spaces and children, creating/updating/deleting pages, managing attachments, comments, content properties, exporting pages, and profile management. Access is controlled via an allowlist and denylist at the subcommand level — by default all commands are permitted.",
  "commands": [
    "read <pageId|url> [--format text|html|markdown]                                      — read page content",
    "info <pageId|url>                                                                     — get page metadata",
    "search <query> [--limit <n>]                                                          — search for pages",
    "spaces                                                                                — list all spaces",
    "find <title> [--space <key>]                                                          — find page by title",
    "children <pageId> [--recursive] [--max-depth <n>] [--format list|tree|json]          — list child pages",
    "create <title> <spaceKey> [--content <text>] [--file <path>] [--format markdown|html|storage] — create page",
    "create-child <title> <parentId> [--content <text>] [--file <path>]                   — create child page",
    "copy-tree <sourceId> <targetParentId> [newTitle] [--max-depth <n>] [--dry-run]       — copy page tree",
    "update <pageId> [--title <t>] [--content <text>] [--file <path>]                     — update page",
    "move <pageId|url> <newParentId|url> [--title <t>]                                    — move page",
    "delete <pageId|url> [--yes]                                                           — delete page",
    "edit <pageId> [--output <file>]                                                       — export page for editing",
    "attachments <pageId|url> [--pattern <glob>] [--download] [--dest <dir>]              — list or download attachments",
    "attachment-upload <pageId|url> --file <path> [--replace]                             — upload attachment",
    "attachment-delete <pageId|url> <attachmentId> [--yes]                                — delete attachment",
    "comments <pageId|url> [--format text|markdown|json] [--location inline|footer]       — list comments",
    "comment <pageId|url> --content <text> [--parent <id>] [--location inline|footer]     — create comment",
    "comment-delete <commentId> [--yes]                                                    — delete comment",
    "property-list <pageId|url>                                                            — list content properties",
    "property-get <pageId|url> <key>                                                       — get content property",
    "property-set <pageId|url> <key> --value <json>                                       — set content property",
    "property-delete <pageId|url> <key> [--yes]                                           — delete content property",
    "export <pageId|url> [--format markdown|html|text] [--dest <dir>]                     — export page + attachments",
    "profile list                                                                          — list configuration profiles",
    "profile use <name>                                                                    — switch active profile",
    "profile add <name> [--domain <d>] [--auth-type basic|bearer] [--token <t>]           — add profile",
    "profile remove <name>                                                                 — remove profile",
    "stats                                                                                 — view usage statistics"
  ],
  "target": "gateway",
  "config": {
    "allowCommands": {
      "type": "string | string[]",
      "description": "If set, only these command paths are permitted. A command path is the leading subcommand token(s) before any flags, e.g. 'read', 'search', 'create', 'profile list'. Prefix matching applies: 'create' covers 'create-child' as well. Omit to allow all commands (subject to denyCommands).",
      "example": ["read", "search", "info", "spaces", "find", "children"]
    },
    "denyCommands": {
      "type": "string | string[]",
      "description": "These command paths are always blocked, even if listed in allowCommands. Deny beats allow. Prefix matching applies: 'create' blocks both 'create' and 'create-child'. Defaults to [] (nothing blocked) when no config is provided.",
      "example": ["create", "update", "delete", "move"]
    },
    "timeout": {
      "type": "number",
      "description": "Timeout in seconds for each confluence invocation. Default: 30.",
      "default": 30
    },
    "profile": {
      "type": "string",
      "description": "Default profile name. Prepended as --profile <value> to every call when --profile is not already in the agent's args. Optional.",
      "example": "production"
    }
  }
}
