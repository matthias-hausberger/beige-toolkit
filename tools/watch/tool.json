{
  "$schema": "https://matthias-hausberger.github.io/beige-toolkit/schemas/tool.json",
  "name": "watch",
  "version": "1.0.0",
  "description": "Monitor files and directories for changes",
  "tools": {
    "watch": {
      "description": "Monitor files and directories for changes (create, modify, delete, rename). Can execute commands on change.",
      "parameters": {
        "type": "object",
        "properties": {
          "command": {
            "type": "string",
            "enum": ["start", "stop", "list", "clear", "history"],
            "description": "The watch command to execute"
          },
          "path": {
            "type": "string",
            "description": "Path to watch (for start command)"
          },
          "watcherId": {
            "type": "string",
            "description": "Watcher ID to stop (for stop command)"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["create", "modify", "delete", "rename"]
            },
            "description": "Events to watch for (default: all)"
          },
          "pattern": {
            "type": "string",
            "description": "Glob pattern to filter files (e.g., '**/*.ts')"
          },
          "commandOnEvent": {
            "type": "string",
            "description": "Command to execute when an event occurs. Supports placeholders: {file}, {event}, {path}"
          },
          "debounce": {
            "type": "number",
            "description": "Debounce time in milliseconds (default: 100)"
          },
          "recursive": {
            "type": "boolean",
            "description": "Watch directories recursively (default: true)"
          },
          "limit": {
            "type": "number",
            "description": "Limit for history command (default: 50)"
          }
        },
        "required": ["command"]
      }
    }
  },
  "config": {
    "type": "object",
    "properties": {
      "allowPaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of path patterns that are allowed to be watched (supports glob patterns)"
      },
      "denyPaths": {
        "type": "array",
        "items": { "type": "string" },
        "description": "List of path patterns that are denied from watching (supports glob patterns)"
      },
      "maxWatchers": {
        "type": "number",
        "description": "Maximum number of concurrent watchers (default: 10)"
      },
      "maxHistorySize": {
        "type": "number",
        "description": "Maximum number of events to keep in history (default: 1000)"
      },
      "defaultDebounce": {
        "type": "number",
        "description": "Default debounce time in milliseconds (default: 100)"
      }
    }
  }
}
